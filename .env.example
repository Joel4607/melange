# ---------------------------------------------------------------------------
# Supabase (create a project at https://supabase.com, then Project Settings ->
# API). Copy this file to `.env.local` and fill in the values.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Used by privileged server code (ledger writes, trust recompute
# job). NEVER expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------------
# Telegram admin bot (added later, when the admin console is built)
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# ---------------------------------------------------------------------------
# Email notifications (Resend) — added later
# ---------------------------------------------------------------------------
RESEND_API_KEY=
