# ---------------------------------------------------------------------------
# Supabase (Project Settings -> API). Copy this file to `.env.local`.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. NEVER expose this to the browser or commit it.
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------------
# Upstash Redis (console.upstash.com -> database -> REST API). Optional:
# powers runner live-location presence + rate limiting; the app degrades
# gracefully (Postgres-only) when unset. Server-only.
# ---------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---------------------------------------------------------------------------
# Map tiles. Optional: falls back to OpenStreetMap if unset. Provide either a
# custom tile URL template or a Mapbox access token. Client-side.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_MAP_TILE_URL=
NEXT_PUBLIC_MAP_ATTRIBUTION=
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# ---------------------------------------------------------------------------
# VAPID web push notifications. Generate a key pair with:
#   node --import tsx scripts/generate-vapid.ts
# NEXT_PUBLIC_VAPID_PUBLIC_KEY is client-side; VAPID_PRIVATE_KEY is server-only.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@melange.app
